# =====================================================
# AccessAI — Environment Variables
# Copy to .env and edit as needed
# =====================================================

# App
APP_NAME=AccessAI
APP_ENV=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Ollama — local LLM runtime
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3
OLLAMA_TIMEOUT=120
OLLAMA_MAX_RETRIES=3

# Browser
BROWSER_HEADLESS=true
SCAN_TIMEOUT=60
SCREENSHOT_ENABLED=true
MAX_PAGES_PER_SCAN=5

# Storage
DATABASE_URL=sqlite+aiosqlite:///./data/accessai.db
REPORTS_DIR=data/reports
SCREENSHOTS_DIR=data/screenshots

# Security
MAX_URL_LENGTH=2048
RATE_LIMIT_SCANS_PER_HOUR=20
